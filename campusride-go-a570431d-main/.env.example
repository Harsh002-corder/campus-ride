# Frontend environment template
# Copy this file to .env and adjust values.

# API base used by frontend HTTP calls
# Local desktop default:
VITE_API_BASE_URL=http://localhost:4000/api

# Optional explicit socket base (if omitted, it is derived from VITE_API_BASE_URL)
# Useful for LAN/mobile testing against your PC IP:
# VITE_SOCKET_BASE_URL=http://192.168.31.183:4000

# Google Maps JavaScript API key
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Optional: stop suggestions from backend endpoint
VITE_USE_REMOTE_STOP_SUGGEST=true
